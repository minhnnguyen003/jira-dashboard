# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
# Local/production env files are gitignored
.env.local
.env.prod
.env.*.local
.env.*.prod
# But commit examples for documentation
!.env.example
!.env.local.example
!.env.prod.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
