# Jira Dashboard Environment Variables
# Copy this file to .env.local and fill in your values

# Jira Cloud instance URL (e.g., https://your-domain.atlassian.net)
JIRA_BASE_URL=https://your-domain.atlassian.net

# Preferred: Bearer Token (recommended)
JIRA_BEARER_TOKEN=your-bearer-token-here

# Alternative: Basic Auth credentials (email:api_token)
# JIRA_EMAIL=your-email@company.com
# JIRA_API_TOKEN=your-api-token-here

# Public Jira URL for links (NEXT_PUBLIC_ prefix makes it available client-side)
NEXT_PUBLIC_JIRA_BASE_URL=https://your-domain.atlassian.net

# For Jira Server/Data Center, use:
# JIRA_BASE_URL=http://your-jira-server:8080
# JIRA_USERNAME=your-username
# JIRA_PASSWORD=your-password

# Next.js will automatically load .env.local
# Do NOT commit .env.local to version control
